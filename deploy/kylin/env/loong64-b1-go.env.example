HTTP_ADDR=0.0.0.0:8080
APP_ENV=production
DEV_AUTH_BYPASS=false
SESSION_COOKIE_NAME=loong64_b1_session
CSRF_COOKIE_NAME=loong64_b1_csrf
SESSION_TTL=168h
SESSION_REFRESH_INTERVAL=15m
SESSION_CLEANUP_INTERVAL=1h
SESSION_SECURE_COOKIE=true
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_SHUTDOWN_TIMEOUT=10s
READY_TIMEOUT=3s
STORAGE_ROOT=/var/lib/loong64-b1-go/storage
RUNTIME_CONFIG_PATH=/etc/loong64-b1-go/runtime.json
MIGRATIONS_DIR=/opt/loong64-b1-go/migrations
DB_DRIVER=sqlite
SQLITE_PATH=/var/lib/loong64-b1-go/data/loong64-b1-go.db
AUTO_MIGRATE=true
DATABASE_URL=postgres://loong64_b1:CHANGE_ME@127.0.0.1:5432/loong64_b1?sslmode=disable
DB_MAX_CONNS=20
MAX_UPLOAD_BYTES=52428800
MAX_ARTIFACTS_PER_SUBMISSION=20
AI_GATEWAY_BASE_URL=http://127.0.0.1:8081
AI_GATEWAY_API_KEY=
AI_GATEWAY_TIMEOUT=10s
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=
LLM_MODEL=local-model
LLM_TIMEOUT=30s
